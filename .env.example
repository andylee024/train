# Train environment — copy to .env and fill in.
#
# `bin/train init-env` will create .env from this file and pull existing
# values from /tmp/train_admin_secret.txt if present.

# --- Linq SMS gateway ---
# Currently piggybacking on the lobs-ai number; provision a dedicated one
# for Train before adding F&F athletes beyond #1.
LINQ_API_BASE_URL=https://api.linqapp.com/api/partner
LINQ_API_KEY=
LINQ_FROM_NUMBER=+1

# --- Anthropic API (forwarded to the Claude Agent SDK) ---
ANTHROPIC_API_KEY=

# --- Train admin ---
# Random 32-byte url-safe; used by bin/train approve to auth /admin/approve.
TRAIN_ADMIN_SECRET=

# E.164. notify_andy SMS land here when an athlete completes intake.
TRAIN_ANDY_PHONE=+1

# --- Modal app URL (override if you redeploy elsewhere) ---
TRAIN_WEB_URL=https://andylee024--train-web.modal.run

# --- Agent runtime (only consumed inside the Modal container) ---
TRAIN_AGENT_MODEL=claude-sonnet-4-6
TRAIN_AGENT_PIN_HOME=1
TRAIN_AGENT_DEBUG=0
TRAIN_AGENT_CWD=/workspace/user

# --- Misc ---
LOG_LEVEL=INFO
