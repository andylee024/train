# Dashboard env vars
#
# These can live here as `web/dashboard/.env.local` OR in the repo root `.env`.
# `next.config.ts` loads the repo-root `.env` first so the dashboard, the
# Python skills, and the TS CLI all share one source of truth. A dashboard-
# local `.env.local` (if you create one) wins over the root file.

# --- Anthropic API (used by /api/synthesize) ---
# Required for /api/synthesize to call Claude (otherwise the route silently
# returns a mocked plan with `synthesized: false`):
ANTHROPIC_API_KEY=sk-ant-...

# --- Bundle write toggle ---
# When unset (default), /api/activate runs in dry-run mode and returns
# structured JSON without touching the filesystem. Set to "1" or "true"
# to actually materialize the arc bundle on disk.
WRITE_BUNDLE_TO_DISK=

# --- Linq SMS (used by /api/welcome-sms) ---
# Reuse the same secrets configured for the Modal app (train-text-secrets).
# Linq partner-API v2: POST {base}/v2/chats with X-LINQ-INTEGRATION-TOKEN.
LINQ_API_BASE_URL=
LINQ_API_KEY=
LINQ_FROM_NUMBER=

# --- Supabase (optional, only for Supabase-backed pages) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
