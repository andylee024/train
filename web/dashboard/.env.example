# web/dashboard environment — copy to .env.local and fill in.

# --- Anthropic API (used by /api/synthesize) ---
ANTHROPIC_API_KEY=

# --- Bundle write toggle ---
# When unset (default), /api/activate runs in dry-run mode and returns
# structured JSON without touching the filesystem. Set to "1" or "true"
# to actually materialize the arc bundle on disk.
WRITE_BUNDLE_TO_DISK=

# --- Linq SMS (used by /api/welcome-sms) ---
# Reuse the same secrets configured for the Modal app (train-text-secrets).
# Linq partner-API v2: POST {base}/v2/chats with X-LINQ-INTEGRATION-TOKEN.
LINQ_API_BASE_URL=
LINQ_API_KEY=
LINQ_FROM_NUMBER=
