# Dashboard env vars
#
# These can live here as `web/dashboard/.env.local` OR in the repo root `.env`.
# `next.config.ts` loads the repo-root `.env` first so the dashboard, the
# Python skills, and the TS CLI all share one source of truth. A dashboard-
# local `.env.local` (if you create one) wins over the root file.
#
# Required for /api/synthesize to call Claude (otherwise the route silently
# returns a mocked plan with `synthesized: false`):
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed for Supabase-backed pages:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
